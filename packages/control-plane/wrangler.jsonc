// Test-only config. Production deployment is managed via Terraform.
{
  "name": "open-inspect-control-plane-test",
  "main": "src/index.ts",
  "compatibility_date": "2024-12-30",
  "durable_objects": {
    "bindings": [{ "name": "SESSION", "class_name": "SessionDO" }],
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["SessionDO"] }],
  "d1_databases": [
    {
      "binding": "DB",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "database_name": "open-inspect-test",
    },
  ],
  "kv_namespaces": [{ "binding": "REPOS_CACHE", "id": "00000000000000000000000000000000" }],
  "vpc_services": [
    {
      "binding": "VPC_SERVICE",
      "service_id": "019cb052-716e-7d82-9e3a-43ce87886afc",
      "remote": true,
    },
  ],
}
